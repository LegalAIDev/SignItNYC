# Copy this file to .env and fill in real values before running scripts.
# Never commit .env — it is listed in .gitignore.

# Google Places API (Text Search) — used by enrich_restaurants.py
# Get a key at: https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Hunter.io Domain Search — used by enrich_restaurants.py
# Get a key at: https://hunter.io/api-keys
HUNTER_API_KEY=your_hunter_api_key_here

# NYC Open Data app token — optional, avoids rate limiting in new_restaurants.py and pull_dob.py
# Register free at: https://data.cityofnewyork.us/profile/app_tokens
NYC_OPEN_DATA_TOKEN=your_nyc_open_data_token_here
